# Core behavior
BUSINESS_TIMEZONE=America/New_York
UNIFI_WEBHOOK_SECRET=
NOTIFICATION_DEDUPE_WINDOW_MS=120000

# Auth behavior
AUTH_CHECK_REVOKED=true

# Shared-project isolation (applies to new collections only)
COLLECTION_PREFIX=test

# Notifications
ENABLE_TOPIC_FALLBACK=true

# AWS / S3 evidence
ENABLE_S3=false
AWS_REGION=
AWS_BUCKET=
DEFAULT_LOT_ID=default_lot
VIOLATION_URL_TTL_SECONDS=600
S3_UPLOAD_TIMEOUT_MS=10000
