    {
      "name": "Violation Assign",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "x-test-user", "value": "{{testUserAdmin}}" }
        ],
        "body": { "mode": "raw", "raw": "{\"assignedToUserId\":\"uid_operator_001\"}" },
        "url": "{{baseUrl}}/violations/{{violationId}}/assign"
      }
    },
    {
      "name": "Violation Acknowledge",
      "request": {
        "method": "POST",
        "header": [
