  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health"
      }
    },
    {
      "name": "Paid Event",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "x-api-client-secret", "value": "{{postmanClientSecret}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"sourceKey\": \"postman-main-gate-entry\",\n  \"externalEventId\": \"pm_evt_paid_001\",\n  \"eventType\": \"entry\",\n  \"capturedAt\": \"{{$isoTimestamp}}\",\n  \"plate\": \"PAY1234\",\n  \"plateConfidence\": 0.96,\n  \"cameraLabel\": \"Entry Gate Camera\",\n  \"direction\": \"entry\",\n  \"metadata\": {\n    \"lane\": \"lane-1\",\n    \"notes\": \"paid event\"\n  }\n}"
        },
        "url": "{{baseUrl}}/webhooks/postman/events"
      }
    },
    {
      "name": "Unpaid Event",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "x-api-client-secret", "value": "{{postmanClientSecret}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"sourceKey\": \"postman-main-gate-entry\",\n  \"externalEventId\": \"pm_evt_unpaid_001\",\n  \"eventType\": \"entry\",\n  \"capturedAt\": \"{{$isoTimestamp}}\",\n  \"plate\": \"UNPD001\",\n  \"plateConfidence\": 0.93,\n  \"cameraLabel\": \"Entry Gate Camera\",\n  \"direction\": \"entry\",\n  \"metadata\": {\n    \"lane\": \"lane-1\",\n    \"notes\": \"unpaid event\"\n  }\n}"
        },
        "url": "{{baseUrl}}/webhooks/postman/events"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const body = pm.response.json();",
              "if (body?.data?.violationId) { pm.environment.set('violationId', body.data.violationId); }",
              "if (body?.data?.eventId) { pm.environment.set('eventId', body.data.eventId); }"
            ]
          }
        }
      ]
    },
