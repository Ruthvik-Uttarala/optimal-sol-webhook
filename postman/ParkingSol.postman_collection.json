    {
      "name": "Dismiss Candidate Event",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "x-api-client-secret", "value": "{{postmanClientSecret}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"sourceKey\": \"postman-main-gate-entry\",\n  \"externalEventId\": \"pm_evt_unpaid_002\",\n  \"eventType\": \"entry\",\n  \"capturedAt\": \"{{$isoTimestamp}}\",\n  \"plate\": \"UNPD002\",\n  \"plateConfidence\": 0.92,\n  \"cameraLabel\": \"Entry Gate Camera\",\n  \"direction\": \"entry\",\n  \"metadata\": {\n    \"lane\": \"lane-1\",\n    \"notes\": \"dismiss candidate\"\n  }\n}"
        },
        "url": "{{baseUrl}}/webhooks/postman/events"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const body = pm.response.json();",
              "if (body?.data?.violationId) { pm.environment.set('dismissViolationId', body.data.violationId); }"
            ]
          }
        }
