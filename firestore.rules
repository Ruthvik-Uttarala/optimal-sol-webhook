rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    // Core operational collections require authentication.
    match /events/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /violations/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /parkingEntries/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /paidSessions/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /plateIndex/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Default deny for all remaining paths.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
