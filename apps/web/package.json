{
  "name": "@parking-sol/web",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json && vite build --configLoader native",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo \"web lint placeholder\"",
    "test": "vitest run --pool threads --poolOptions.threads.singleThread",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@parking-sol/shared": "1.0.0",
    "@tanstack/react-query": "5.66.9",
    "axios": "1.8.4",
    "clsx": "2.1.1",
    "firebase": "12.11.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-hook-form": "7.54.2",
    "react-router-dom": "7.13.2",
    "sonner": "2.0.1",
    "zod": "3.24.2",
    "zustand": "5.0.3"
  },
  "devDependencies": {
    "@playwright/test": "1.51.1",
    "@testing-library/dom": "10.4.0",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.2.0",
    "@testing-library/user-event": "14.6.1",
    "@types/react": "18.3.18",
    "@types/react-dom": "18.3.5",
    "@vitejs/plugin-react": "6.0.1",
    "autoprefixer": "10.4.20",
    "jsdom": "26.0.0",
    "postcss": "8.4.49",
    "tailwindcss": "3.4.17",
    "typescript": "5.8.2",
    "vite": "8.0.3",
    "vitest": "3.0.5"
  },
  "vitest": {
    "environment": "jsdom",
    "setupFiles": [
      "./src/tests/setup.ts"
    ],
    "exclude": [
      "e2e/**",
      "node_modules/**"
    ]
  }
}
