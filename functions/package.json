{
  "name": "@parking-sol/functions",
  "private": true,
  "main": "lib/index.js",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo \"functions lint placeholder\"",
    "test": "npm run build && node lib/scripts/runApiAssertions.js",
    "test:api": "npm run build && node lib/scripts/runApiAssertions.js",
    "test:rules:unit": "npm run build && node lib/scripts/runFirestoreRulesAssertions.js",
    "newman": "npm run build && node lib/scripts/runNewmanLocal.js",
    "newman:raw": "newman run ../postman/ParkingSol.postman_collection.json -e ../postman/ParkingSol.postman_environment.json"
  },
  "dependencies": {
    "@parking-sol/shared": "file:vendor/parking-sol-shared-1.0.0.tgz",
    "cors": "2.8.5",
    "dayjs": "1.11.13",
    "express": "4.21.2",
    "firebase-admin": "13.7.0",
    "firebase-functions": "7.2.2",
    "uuid": "11.1.0",
    "zod": "3.24.2"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "5.0.0",
    "@types/cors": "2.8.17",
    "@types/express": "5.0.0",
    "@types/node": "22.13.10",
    "@types/supertest": "6.0.3",
    "eslint": "9.22.0",
    "newman": "6.2.1",
    "supertest": "7.0.0",
    "tsx": "4.19.3",
    "typescript": "5.8.2",
    "vitest": "3.0.5"
  }
}
